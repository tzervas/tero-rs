// nodule: h1_unsigned
// @summary: H1 capstone demo (M-914) — the unsigned integer op set.
nodule h1_unsigned;

// `add_u`/`sub_u`/`div_u`/`rem_u`/`shl_u`/`shr_u` (RFC-0033 §4.1.2/§4.1.3 Gap B). Every op
// self-checks against a hand-derived expectation and folds into one `Binary{1}` truth value.
pub fn unsigned_checks() => Binary{1} =
  and(and(eq(add_u(0b0000_0001, 0b0000_0010), 0b0000_0011), eq(sub_u(0b0000_0101, 0b0000_0010), 0b0000_0011)), and(and(eq(div_u(0b0000_0111, 0b0000_0010), 0b0000_0011), eq(rem_u(0b0000_0111, 0b0000_0010), 0b0000_0001)), and(eq(shl_u(0b0000_0001, 0b0000_0011), 0b0000_1000), eq(shr_u(0b0000_1000, 0b0000_0011), 0b0000_0001))));
